<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- TV apps must not require a touchscreen; on phones/tablets touch is used when present. -->
    <uses-feature
        android:name="android.hardware.touchscreen"
        android:required="false" />

    <!--
      Leanback is supported but NOT required: the app ships to both form factors.
      (leanback required=false) + (touchscreen required=false) + LEANBACK_LAUNCHER intent
      keeps the app installable on Android TV / Google TV while also being offered to
      phones and tablets, where the UI is driven by touch instead of a D-pad.
    -->
    <uses-feature
        android:name="android.software.leanback"
        android:required="false" />

    <application
        android:name=".AmbientApplication"
        android:allowBackup="true"
        android:banner="@drawable/tv_banner"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:localeConfig="@xml/locales_config"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.DxAmbient"
        tools:targetApi="33">

        <activity
            android:name=".MainActivity"
            android:configChanges="orientation|screenSize|keyboardHidden|keyboard|navigation"
            android:exported="true"
            android:label="@string/app_name"
            android:screenOrientation="sensorLandscape"
            android:theme="@style/Theme.DxAmbient.Splash"
            android:windowSoftInputMode="stateAlwaysHidden|adjustResize">

            <!-- Phone/tablet launcher. -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- Android TV / Google TV launcher. -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LEANBACK_LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>
