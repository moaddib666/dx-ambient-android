<?xml version="1.0" encoding="utf-8"?>
<!--
  TV-flavor overlay: Play's Android TV form-factor tracks (tv:internal, tv:TV, …) only
  accept artifacts that REQUIRE leanback, so this flips the main manifest's optional
  declaration to required for the `tv` flavor only. The mobile flavor stays universal.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-feature
        android:name="android.software.leanback"
        android:required="true"
        tools:node="replace" />

</manifest>
